# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

#idea
.idea
/files/
/maven-files/
/nexus-data/
.nexus-test-password
**/config.local.yml
/node_modules/
/static/output.css
**/.DS_Store
openspmregistry
openspmregistry.e2e
e2e-file-repo
testdata/e2e/Consumer/Package.resolved
# Leftover from swift package archive-source in fixture dirs (e2e uses package-registry publish)
testdata/e2e/**/*.zip
cover.out
SPM-Registry-Spec.md
CHANGELOG.md.tmp
.vscode/**
**/.build
**/.build
**/.swiftpm/**

# cmds
/e2e-generate-certs
